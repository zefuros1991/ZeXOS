# caches and runtime data (ignore noisy runtime junk)
.cache/
.local/cache/
.local/state/
.var/

# browser / dev tool caches
vscode*/Cache/
Code/Cache/
VSCodium/Cache/

# game / compatibility layers (runtime only)
steam/
wine/
proton/

# OS junk
*.log
*.tmp
*.bak
*.swp

# system artifacts
.Trash-*
.nvidia*
.pulse-cookie
.Xauthority

# Zsh runtime artifacts (IMPORTANT)
.zcompdump*

# Fish's own auto-rewritten universal variable store (theme/prompt settings
# fish itself regenerates on every `set -U`). Not hand-edited, and tracking it
# would cause git diff noise unrelated to real config changes. Regenerates
# fine on a fresh machine when fish/plugins first run.
stow/fish/.config/fish/fish_variables
**/vscode/**/globalStorage/
.vscode/
**/globalStorage/
**/cache/
stow/vscode/.config/Code/User/globalStorage/saoudrizwan.claude-dev/cache/

# stow-adopt backups and stray root symlink — machine-local, never commit
backup/
/.config

# Electron / Chromium app DATA (cookies, session tokens, caches) — config only in git!
**/Cache/
**/CachedData/
**/CachedProfilesData/
**/Code Cache/
**/GPUCache/
**/DawnGraphiteCache/
**/DawnWebGPUCache/
**/blob_storage/
**/Session Storage/
**/Local Storage/
**/IndexedDB/
**/databases/
**/Service Worker/
**/Crashpad/
**/Dictionaries/
**/component_crx_cache/
**/Cookies*
**/Network Persistent State*
**/TransportSecurity*
**/Trust Tokens*
**/SharedStorage*
**/sessionData/
**/Singleton*

# VSCode/VSCodium: keep settings.json/keybindings/snippets, drop state DBs & history
**/workspaceStorage/
**/History/
**/Backups/
**/logs/
**/*.vscdb
**/*.vscdb.backup

# more Electron/VSCodium data-not-config
**/CachedExtensionVSIXs/
**/Shared Dictionary/
**/DIPS
**/Preferences
**/WebStorage/
**/languagepacks.json

# telemetry state
**/go/telemetry/

# Spicetify Marketplace: this is a downloaded, self-updating third-party
# bundle (installed by the Marketplace app itself), not hand-authored config.
# Tracking it just means diff noise every time it auto-updates.
stow/spicetify/.config/spicetify/CustomApps/marketplace/

# VS Code Settings Sync's own local cache: timestamped snapshot files that
# accumulate forever and are regenerated automatically. Settings Sync already
# syncs this data to the cloud on its own, so tracking a local copy in git is
# redundant and just grows the repo over time.
stow/vscode/.config/Code/User/sync/
