// Static fallback output layout.
//
// This file only sets sane defaults for niri at compositor startup. Dynamic
// docked/undocked switching (enabling the external monitor and disabling the
// laptop panel, or vice versa) is handled at runtime by kanshi — see
// ~/.config/kanshi/config and `systemctl --user status kanshi`.
//
// Both outputs are kept ENABLED here on purpose: if kanshi is ever not
// running (crashed, not yet started), niri must never boot into a state
// where the laptop panel is forced off. That was the bug with the old
// Monique-generated static "off" block — it persisted across reboots and
// docking states with no way to react to what was actually connected.

output "Samsung Electric Company Odyssey G85SD H1AK500000" {
    mode "3440x1440@119.960"
    scale 1.1
    position x=0 y=0
    variable-refresh-rate
}

// Laptop panel, matched by EDID description instead of connector name —
// the connector is not stable across boots/drivers (seen as both eDP-1
// and eDP-1-0 on this machine). The double space before "Unknown" is
// intentional; it's the exact string niri reports in `niri msg outputs`.
output "Samsung Display Corp. ATNA60DL04-0  Unknown" {
    scale 1.0
}
